{
  "manifest_version": 3,
  "name": "Gmail Seen Tracker",
  "version": "1.0",
  "permissions": ["storage", "scripting"],
  "host_permissions": [
    "https://mail.google.com/*",
    "http://localhost:3000/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"]
    }
  ]
}